<?xml version="1.0" encoding="utf-8"?>
<!--Todo : Gradient-->
<com.scwang.smart.refresh.layout.SmartRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:id="@+id/main"
    android:background="@color/primary_50">

    <com.scwang.smart.refresh.header.ClassicsHeader
        android:id="@+id/classicHeader"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:srlAccentColor="@color/white"
        app:srlEnableLastTime="false"/>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:contentDescription="@null"
            android:src="@drawable/ill_bg_promo_coupon_decoration_placeholder"/>

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:clipChildren="false"
            android:elevation="12dp"
            app:elevation="12dp">

            <com.google.android.material.appbar.CollapsingToolbarLayout
                android:id="@+id/collapsingToolbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:contentScrim="@color/white"
                app:expandedTitleTextAppearance="@style/TextAppearance.Inter.Semibold.H1"
                app:expandedTitleTextColor="@color/white"
                app:collapsedTitleTextAppearance="@style/TextAppearance.Inter.Semibold.H1"
                app:titleCollapseMode="scale"
                app:expandedTitleGravity="top"
                app:expandedTitleMarginTop="12dp"
                app:expandedTitleMarginStart="60dp"
                app:layout_scrollFlags="scroll|exitUntilCollapsed">

                <com.google.android.material.appbar.MaterialToolbar
                    android:id="@+id/toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    app:contentInsetStartWithNavigation="0dp"
                    app:contentInsetStart="0dp"
                    app:contentInsetEnd="0dp"
                    app:titleMarginTop="0dp"
                    app:titleMarginBottom="0dp"
                    app:navigationIconTint="@color/white"
                    android:minHeight="@dimen/dimen_0"
                    app:navigationIcon="@drawable/ic_arrow_left"
                    app:title="Promo Ongkir"
                    app:layout_collapseMode="pin"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/liquidGlassCard"
                    android:layout_width="match_parent"
                    android:layout_height="78dp"
                    android:layout_marginTop="64dp"
                    android:layout_marginBottom="32dp"
                    android:layout_marginHorizontal="16dp"
                    app:cardBackgroundColor="#23FFFFFF"
                    app:layout_collapseMode="parallax">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <TextView
                            android:id="@+id/tvTest"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="@dimen/s"
                            android:textAppearance="@style/TextAppearance.Inter.Medium.B3"
                            android:text="This is long text that is 2 line long that will be so long and a Liquid Glass Card Placeholder"
                            android:lineSpacingExtra="@dimen/xxxs"
                            android:textColor="@color/white"
                            app:layout_constrainedWidth="true"
                            app:layout_constraintEnd_toStartOf="@id/chipTest"
                            app:layout_constraintHorizontal_chainStyle="packed"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintHorizontal_bias="0.0" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipTest"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:chipMinTouchTargetSize="@dimen/dimen_0"
                            app:layout_constraintStart_toEndOf="@id/tvTest"
                            app:layout_constraintEnd_toStartOf="@id/chevronTest"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/chevronTest"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/xs"
                            android:button="@drawable/ic_arrow_left"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </com.google.android.material.card.MaterialCardView>

            </com.google.android.material.appbar.CollapsingToolbarLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/stickyTabContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:shapeAppearance="@style/ShapeAppearance.EDTS.UIKit.Flat.Corner.Bottom.16"
                app:cardElevation="@dimen/dimen_0"
                app:strokeWidth="@dimen/dimen_0"
                app:strokeColor="@color/white"
                android:clipChildren="false"
                app:contentPadding="-4dp"
                app:cardPreventCornerOverlap="true"
                android:background="@color/white"
                android:elevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:clipChildren="false">

                    <com.google.android.material.tabs.TabLayout
                        android:id="@+id/tlLevel1"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:paddingHorizontal="@dimen/xxs"
                        android:background="@color/transparent"
                        android:clipToPadding="false"
                        app:tabPaddingStart="4dp"
                        app:tabPaddingEnd="8dp"
                        app:tabTextAppearance="@style/TextAppearance.Inter.SemiBold.B3"
                        app:tabTextColor="@color/black_40"
                        app:tabSelectedTextColor="@color/primary_30"
                        app:tabMode="scrollable"
                        app:tabGravity="start">

                        <com.google.android.material.tabs.TabItem
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Diskon Ongkir"/>

                        <com.google.android.material.tabs.TabItem
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Potongan Total"/>

                        <com.google.android.material.tabs.TabItem
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Diskon Alat Bayar"/>

                    </com.google.android.material.tabs.TabLayout>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:dividerThickness="@dimen/dimen_1"
                        app:dividerColor="@color/black_30"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/black_10">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/cgTabLevel2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/xxs"
                    android:paddingVertical="@dimen/xs"
                    android:background="@color/black_10">

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/m3"
                        app:chipStrokeWidth="@dimen/dimen_0"
                        app:chipCornerRadius="32dp"
                        app:chipBackgroundColor="@color/primary_30"
                        android:textColor="@color/white"
                        android:textAppearance="@style/TextAppearance.Inter.SemiBold.B3"
                        android:text="Semua"
                        app:chipMinTouchTargetSize="@dimen/dimen_0"/>

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/m3"
                        app:chipStrokeWidth="@dimen/dimen_0"
                        app:chipCornerRadius="32dp"
                        app:chipBackgroundColor="@color/black_20"
                        android:textColor="@color/primary_30"
                        android:textAppearance="@style/TextAppearance.Inter.SemiBold.B3"
                        android:text="Xtra"
                        app:chipMinTouchTargetSize="@dimen/dimen_0"/>

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/m3"
                        app:chipStrokeWidth="@dimen/dimen_0"
                        app:chipCornerRadius="32dp"
                        app:chipBackgroundColor="@color/black_20"
                        android:textColor="@color/primary_30"
                        android:textAppearance="@style/TextAppearance.Inter.SemiBold.B3"
                        android:text="Xpress"
                        app:chipMinTouchTargetSize="@dimen/dimen_0"/>

                </com.google.android.material.chip.ChipGroup>

            </FrameLayout>

        </com.google.android.material.appbar.AppBarLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCoupons"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="@dimen/xs"
            android:background="@color/black_10"
            android:clipToPadding="false"
            android:orientation="vertical"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_promotion_coupon"
            app:layout_behavior="@string/appbar_scrolling_view_behavior" />


    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</com.scwang.smart.refresh.layout.SmartRefreshLayout>