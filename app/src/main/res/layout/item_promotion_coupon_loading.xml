<?xml version="1.0" encoding="utf-8"?>
<com.facebook.shimmer.ShimmerFrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/greyScale"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dimen_6"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:padding="@dimen/xs">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivCouponImage"
            android:layout_width="@dimen/dimen_0"
            android:layout_height="@dimen/dimen_0"
            android:minHeight="@dimen/dimen_60"
            android:adjustViewBounds="true"
            app:srcCompat="@color/shimmerSkeleton"
            app:shapeAppearance="@style/ShapeAppearance.EDTS.UIKit.MediumComponent"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/tvTitle2"/>

        <View
            android:id="@+id/couponTypeBadge"
            android:layout_width="@dimen/dimen_48"
            android:layout_height="@dimen/dimen_20"
            android:layout_marginStart="@dimen/xxs"
            android:background="@drawable/bg_skeleton_shimmer_4"
            app:layout_constrainedWidth="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivCouponImage"
            app:layout_constraintHorizontal_bias="0.0"/>

        <View
            android:id="@+id/tvTitle"
            android:layout_width="@dimen/dimen_0"
            android:layout_height="@dimen/dimen_14"
            android:layout_margin="@dimen/xxs"
            android:background="@drawable/bg_skeleton_shimmer_4"
            app:layout_constraintTop_toBottomOf="@id/couponTypeBadge"
            app:layout_constraintStart_toEndOf="@id/ivCouponImage"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/tvTitle2"
            android:layout_width="102dp"
            android:layout_height="@dimen/dimen_14"
            android:layout_marginTop="@dimen/xxxs"
            android:layout_marginHorizontal="@dimen/xxs"
            android:background="@drawable/bg_skeleton_shimmer_4"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toEndOf="@id/ivCouponImage"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"/>

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/headerBarrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:constraint_referenced_ids="tvTitle, tvTitle2"
            app:barrierDirection="bottom"/>

        <FrameLayout
            android:id="@+id/flItem1"
            android:layout_width="@dimen/dimen_0"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/xs"
            app:layout_constraintTop_toBottomOf="@id/headerBarrier"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <View
                    android:id="@+id/tvStart"
                    android:layout_width="109dp"
                    android:layout_height="@dimen/dimen_14"
                    android:background="@drawable/bg_skeleton_shimmer_4"
                    app:layout_constraintHorizontal_chainStyle="spread_inside"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/tvEnd"/>

                <View
                    android:id="@+id/tvEnd"
                    android:layout_width="45dp"
                    android:layout_height="@dimen/dimen_14"
                    android:background="@drawable/bg_skeleton_shimmer_4"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/tvStart"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
            
        </FrameLayout>

        <FrameLayout
            android:id="@+id/flItem2"
            android:layout_width="@dimen/dimen_0"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/xxxs"
            app:layout_constraintTop_toBottomOf="@id/flItem1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <View
                    android:id="@+id/tvStart2"
                    android:layout_width="54dp"
                    android:layout_height="@dimen/dimen_14"
                    android:background="@drawable/bg_skeleton_shimmer_4"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/tvEnd2"
                    app:layout_constraintHorizontal_chainStyle="spread_inside"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/tvEnd2"
                    android:layout_width="56dp"
                    android:layout_height="@dimen/dimen_14"
                    android:background="@drawable/bg_skeleton_shimmer_4"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/tvStart2"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </FrameLayout>

        <FrameLayout
            android:id="@+id/flItem3"
            android:layout_width="@dimen/dimen_0"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/xxxs"
            app:layout_constraintTop_toBottomOf="@id/flItem2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <View
                    android:id="@+id/tvStart3"
                    android:layout_width="89dp"
                    android:layout_height="14dp"
                    android:text="Periode"
                    android:background="@drawable/bg_skeleton_shimmer_4"
                    app:layout_constraintHorizontal_chainStyle="spread_inside"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/tvEnd3"/>

                <View
                    android:id="@+id/tvEnd3"
                    android:layout_width="56dp"
                    android:layout_height="@dimen/dimen_14"
                    android:background="@drawable/bg_skeleton_shimmer_4"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/tvStart3"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </FrameLayout>

        <id.co.edtslib.uikit.divider.DashDivider
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/s"
            app:dividerColor="#E6E9EB"
            app:dividerThickness="2dp"
            app:gapWidth="2dp"
            app:layout_constraintTop_toBottomOf="@id/flItem3"/>

        <View
            android:id="@+id/couponCode"
            android:layout_width="130dp"
            android:layout_height="14dp"
            android:minWidth="140dp"
            android:background="@drawable/bg_skeleton_shimmer_4"
            app:chipCornerRadius="@dimen/xxxs"
            app:layout_constrainedWidth="true"
            app:layout_constraintTop_toTopOf="@id/btnRedeem"
            app:layout_constraintBottom_toBottomOf="@id/btnRedeem"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintHorizontal_bias="0.0"/>

        <TextView
            android:id="@+id/dotDivider"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black_60"
            android:layout_marginStart="@dimen/xxs"
            android:text="•"
            app:layout_constraintTop_toTopOf="@id/couponCode"
            app:layout_constraintStart_toEndOf="@id/couponCode"
            app:layout_constraintBottom_toBottomOf="@id/couponCode"/>

        <View
            android:id="@+id/tvDetailCTA"
            android:layout_width="34dp"
            android:layout_height="@dimen/dimen_14"
            android:layout_marginStart="@dimen/xxs"
            android:background="@drawable/bg_skeleton_shimmer_4"
            app:layout_constraintBottom_toBottomOf="@id/couponCode"
            app:layout_constraintEnd_toStartOf="@+id/btnRedeem"
            app:layout_constraintHorizontal_chainStyle="spread_inside"
            app:layout_constraintStart_toEndOf="@id/dotDivider"
            app:layout_constraintTop_toTopOf="@id/couponCode"
            app:layout_constraintHorizontal_bias="0.0"/>

        <View
            android:id="@+id/btnRedeem"
            android:layout_width="68dp"
            android:layout_height="@dimen/dimen_28"
            android:layout_marginTop="@dimen/xs"
            android:background="@drawable/bg_skeleton_shimmer_4"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.facebook.shimmer.ShimmerFrameLayout>